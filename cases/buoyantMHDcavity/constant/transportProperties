FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

transportModel  Newtonian;

rho             1;

nu              0.001;

sigma           0.001;

mu_m		4e-7;

beta 		1e-02;

TRef	        300.5;

Pr		0.024;

Prt	  	1.0;
